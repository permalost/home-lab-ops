# This is an example file showing the structure of secrets.yaml
# DO NOT use these values in production!
# 
# Generate real secrets with: ./scripts/01-generate-secrets.sh
# 
# The actual secrets.yaml will be automatically generated and should
# contain base64-encoded certificates and keys.

cluster:
  id: "REPLACE-WITH-GENERATED-CLUSTER-ID"
  secret: "REPLACE-WITH-GENERATED-CLUSTER-SECRET"

secrets:
  bootstraptoken: "REPLACE-WITH-BOOTSTRAP-TOKEN"
  secretboxencryptionsecret: "REPLACE-WITH-SECRETBOX-KEY"
  
trustdinfo:
  token: "REPLACE-WITH-TRUSTD-TOKEN"

certs:
  etcd:
    crt: |
      -----BEGIN CERTIFICATE-----
      REPLACE-WITH-ETCD-CERTIFICATE
      -----END CERTIFICATE-----
    key: |
      -----BEGIN EC PRIVATE KEY-----
      REPLACE-WITH-ETCD-KEY
      -----END EC PRIVATE KEY-----
  
  k8s:
    crt: |
      -----BEGIN CERTIFICATE-----
      REPLACE-WITH-K8S-CERTIFICATE
      -----END CERTIFICATE-----
    key: |
      -----BEGIN EC PRIVATE KEY-----
      REPLACE-WITH-K8S-KEY
      -----END EC PRIVATE KEY-----
  
  k8saggregator:
    crt: |
      -----BEGIN CERTIFICATE-----
      REPLACE-WITH-AGGREGATOR-CERTIFICATE
      -----END CERTIFICATE-----
    key: |
      -----BEGIN EC PRIVATE KEY-----
      REPLACE-WITH-AGGREGATOR-KEY
      -----END EC PRIVATE KEY-----
  
  k8sserviceaccount:
    key: |
      -----BEGIN EC PRIVATE KEY-----
      REPLACE-WITH-SERVICE-ACCOUNT-KEY
      -----END EC PRIVATE KEY-----
  
  os:
    crt: |
      -----BEGIN CERTIFICATE-----
      REPLACE-WITH-OS-CERTIFICATE
      -----END CERTIFICATE-----
    key: |
      -----BEGIN EC PRIVATE KEY-----
      REPLACE-WITH-OS-KEY
      -----END EC PRIVATE KEY-----